# ─────────────────────────────────────────────────────────────────────────────
# VO and Visual Extractor — environment configuration (template)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ────────────────────────────────────────────────
# Your GCP project ID (find it in Google Cloud Console → project selector)
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket used for temporary video uploads during analysis
GCS_BUCKET_NAME=your-bucket-name

# Path to the service account JSON key file (relative to the project root).
# Required roles on the service account:
#   - Vertex AI User
#   - Storage Object Admin (on the bucket above)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Vertex AI region (us-central1 supports Gemini 2.5 / 1.5 Pro)
VERTEX_AI_LOCATION=us-central1

# ── Web app auth (Google Workspace SSO) ─────────────────────────────────────
# Sign-in is restricted to a single Google Workspace domain. Only users with
# an @ALLOWED_DOMAIN email can log in.
ALLOWED_DOMAIN=yourcompany.com

# OAuth 2.0 web client credentials (Google Cloud Console → APIs & Services →
# Credentials). The redirect URI must be added to "Authorized redirect URIs"
# on the OAuth client, exactly as written below.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/callback

# Random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-a-long-random-string

# Session cookie lifetime in seconds (default: 30 days)
SESSION_MAX_AGE=2592000

# Cookie Secure flag. Keep "1" in production (HTTPS). Set to "0" only for
# local-HTTP development.
SESSION_HTTPS_ONLY=1

# ── Storage limits (VPS disk) ───────────────────────────────────────────────
# Hard cap on the data/ directory; the server refuses new uploads once full.
STORAGE_LIMIT_GB=50

# Single-file upload cap (large files are still streamed to disk).
MAX_UPLOAD_GB=5

# ── Server ──────────────────────────────────────────────────────────────────
# For local dev, bind to 127.0.0.1. In production with nginx/Caddy in front,
# also bind to 127.0.0.1 (the reverse proxy forwards to this port).
HOST=127.0.0.1
PORT=8000
