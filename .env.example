# ─────────────────────────────────────────────────────────────────────────────
# VO and Visual Extractor — environment configuration (template)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud / Vertex AI ────────────────────────────────────────────────
# Your GCP project ID (find it in Google Cloud Console → project selector)
GCP_PROJECT_ID=your-gcp-project-id

# GCS bucket used for temporary video uploads during analysis
GCS_BUCKET_NAME=your-bucket-name

# Path to the service account JSON key file (relative to the project root).
# Required roles on the service account:
#   - Vertex AI User
#   - Storage Object Admin (on the bucket above)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Vertex AI region (us-central1 supports Gemini 2.5 / 1.5 Pro)
VERTEX_AI_LOCATION=us-central1

# ── Web app auth (shared username + password) ───────────────────────────────
# The web server uses a shared team password (signed-cookie session). Both
# values MUST be set in production — leaving APP_PASSWORD blank disables auth.
APP_USERNAME=team
APP_PASSWORD=change-me-to-something-strong

# Session cookie lifetime in seconds (default: 30 days)
SESSION_MAX_AGE=2592000

# ── Storage limits (VPS disk) ───────────────────────────────────────────────
# Hard cap on the data/ directory; the server refuses new uploads once full.
STORAGE_LIMIT_GB=50

# Single-file upload cap (large files are still streamed to disk).
MAX_UPLOAD_GB=5

# ── Server ──────────────────────────────────────────────────────────────────
# For local dev, bind to 127.0.0.1. In production with nginx in front, also
# bind to 127.0.0.1 (nginx reverse-proxies to this port).
HOST=127.0.0.1
PORT=8000
