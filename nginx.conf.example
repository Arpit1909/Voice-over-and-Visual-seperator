# ─────────────────────────────────────────────────────────────────────────────
#  Example nginx config for the VO and Visual Extractor.
#  Place behind HTTPS (Let's Encrypt). Adjust server_name and TLS cert paths.
# ─────────────────────────────────────────────────────────────────────────────

upstream vo_visual_extractor {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name extractor.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name extractor.example.com;

    # TLS — replace with your own cert paths (e.g. from certbot)
    ssl_certificate     /etc/letsencrypt/live/extractor.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/extractor.example.com/privkey.pem;

    # Allow large uploads (matches MAX_UPLOAD_GB in .env)
    client_max_body_size 5G;
    client_body_timeout  3600s;
    keepalive_timeout    90s;

    # Long-running analyses can take 30+ minutes
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;

    location / {
        proxy_pass         http://vo_visual_extractor;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;        # important for video streaming
        proxy_request_buffering off;   # important for large uploads
    }
}
